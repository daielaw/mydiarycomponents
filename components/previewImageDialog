@Composable
fun PreviewImageDialog(
    url: String,
    onDismiss: () -> Unit
) {
    val imageUrl = url.takeIf { it.isNotBlank() }?.let { buildDownloadImageUrl(it) }
    Dialog(
        onDismissRequest = onDismiss,
        properties = DialogProperties(
            usePlatformDefaultWidth = false,
        )
    ) {
        // Use a Surface or Box to fill the entire screen
        Surface(
            modifier = Modifier.fillMaxSize(),
            color = Color.Black
        ) {
            Box(modifier = Modifier.fillMaxSize()) {

                // 1. The Image Layer
                Zoomable { zoomModifier ->
                    SecuredAsyncImage(
                        url = url,
                        contentDescription = "Full size preview",
                        modifier = zoomModifier.fillMaxSize(),
                        contentScale = ContentScale.Fit
                    )
                }
                /*Zoomable { zoomModifier ->
                    imageUrl?.let {
                        SecuredAsyncImage(
                            url = it,
                            contentDescription = "Full size preview",
                            modifier = zoomModifier.fillMaxSize(),
                            contentScale = ContentScale.Fit
                        )
                    }
                }*/

                // 2. The Close Button (Overlay)
                // Positioned at the top-end for a modern UI feel
                IconButton(
                    onClick = onDismiss,
                    modifier = Modifier
                        .align(Alignment.TopEnd)
                        .padding(16.dp)
                        .statusBarsPadding() // Avoid the notch/status bar
                ) {
                    Icon(
                        imageVector = Icons.Default.Close,
                        contentDescription = "Close",
                        tint = Color.White
                    )
                }
            }
        }
    }
}
